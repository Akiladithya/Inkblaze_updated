# PDF Highlighter Backend Configuration
# Copy this file to .env and update values for your environment

# ── Flask Configuration ────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=false
FLASK_SECRET_KEY=your-secret-key-change-this-in-production

# ── CORS Configuration ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:19000

# ── Security ───────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-this-in-production

# ── Ollama Configuration ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Processing Configuration ──────────────────────────────────────────────────
# TF-IDF percentile threshold for sentence selection (0-100)
IMPORTANCE_PERCENTILE=70

# ── File Upload Configuration ──────────────────────────────────────────────────
# Maximum file size in MB
MAX_FILE_SIZE_MB=50

# Time to live for uploaded files (hours) before cleanup
UPLOAD_TTL_HOURS=24

# ── Server Configuration ───────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=5000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
