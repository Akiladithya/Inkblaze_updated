# PDF Highlighter Frontend Configuration
# Copy this file to .env.local and update values for your environment

# ── API Configuration ─────────────────────────────────────────────────────────
# API Base URL - for development use localhost, for production use your domain
REACT_APP_API_URL=http://localhost:5000

# Optional: JWT token for authenticated requests
# REACT_APP_JWT_TOKEN=your-jwt-token-here

# ── Feature Flags ──────────────────────────────────────────────────────────────
# Enable offline support (stub implementation)
REACT_APP_ENABLE_OFFLINE=false

# Enable error reporting to external service (Sentry, etc)
REACT_APP_ENABLE_ERROR_REPORTING=false

# ── Build Configuration ────────────────────────────────────────────────────────
# Expose Native Modules for Expo (development only)
REACT_APP_EXPO_DEV_CLIENT=true
