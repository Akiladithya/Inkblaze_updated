{
  "expo": {
    "name": "PDF Highlighter",
    "slug": "pdf-highlighter",
    "version": "1.0.0",
    "sdkVersion": "50.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F0F4FF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pdfhighlighter.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F0F4FF"
      },
      "package": "com.pdfhighlighter.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-document-picker"
    ]
  }
}
