{
  "expo": {
    "name": "PDF Highlighter",
    "slug": "pdf-highlighter",
    "version": "1.0.0",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pdfhighlighter.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F0F4FF"
      },
      "package": "com.pdfhighlighter.app"
    },
    "web": {
      "bundler": "metro",
      "port": 8081
    },
    "plugins": [
      "expo-document-picker"
    ]
  }
}
